<Window x:Class="DynamicReportSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DynamicReportSystem.Models"
        mc:Ignorable="d"
        Title="Dynamic Reporting System"
        Height="760"
        Width="1200"
        MinHeight="660"
        MinWidth="980"
        Loaded="Window_Loaded">
    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type models:ExplorerNode}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayText}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Text="Hệ thống tạo báo cáo động" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="SQL được sinh" Padding="12">
                    <TextBox x:Name="txtGeneratedSql"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="10" />
                </GroupBox>

                <GroupBox Grid.Row="2" Header="Tùy chọn truy vấn cơ bản" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="txtSelectedTable"
                                   Grid.Row="0"
                                   FontWeight="SemiBold"
                                   Text="Bảng đã chọn: (chưa chọn)" />

                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <CheckBox x:Name="chkSelect" Content="SELECT" IsChecked="True" Margin="0,0,18,0" />
                            <CheckBox x:Name="chkWhere" Content="WHERE" Margin="0,0,18,0" />
                            <CheckBox x:Name="chkGroupBy" Content="GROUP BY" />
                        </StackPanel>

                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <Button x:Name="btnGenerateSql"
                                    Content="Tạo câu SQL"
                                    Width="130"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="btnGenerateSql_Click" />
                            <Button x:Name="btnReset"
                                    Content="Làm mới"
                                    Width="110"
                                    Height="34"
                                    Click="btnReset_Click" />
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#ECECEC" />

            <Border Grid.Column="2"
                    Padding="10"
                    BorderBrush="#D9D9D9"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Khám phá lược đồ" />

                    <TreeView x:Name="tvExplorer"
                              Grid.Row="1"
                              MouseDoubleClick="tvExplorer_MouseDoubleClick" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
